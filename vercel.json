{
  "version": 2,
  "buildCommand": "cd apps/web && npm ci && npm run build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ],
  "functions": {
    "apps/api/api/index.go": {
      "runtime": "go1.x",
      "includeFiles": "apps/api/scripts/migrations/**"
    }
  }
}
